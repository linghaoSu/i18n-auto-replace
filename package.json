{
  "publisher": "linghaosu",
  "author": {
    "email": "slh001@live.cn",
    "name": "linghao.su"
  },
  "name": "i18n-auto-replace",
  "displayName": "I18n Auto Replace",
  "version": "0.0.12",
  "packageManager": "pnpm@10.33.0",
  "description": "Auto create, open, and sync paired locale JSON files for i18n-enabled projects.",
  "license": "MIT",
  "icon": "resources/icon.png",
  "main": "./dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/linghaoSu/i18n-auto-replace"
  },
  "files": [
    "dist",
    "resources"
  ],
  "engines": {
    "vscode": "^1.68.0",
    "node": ">=20"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "scripts": {
    "dev": "pnpm run build:i18n && pnpm build --watch",
    "pack": "vsce package --no-dependencies",
    "lint": "eslint .",
    "test": "vitest",
    "build:i18n": "esno scripts/build-i18n.ts",
    "build": "pnpm run build:i18n && tsup src/index.ts --external vscode",
    "release": "bumpp --commit --push --tag",
    "publish": "vsce publish --no-dependencies",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "pnpm build"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^0.25.1",
    "@babel/types": "^7.18.4",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.68.0",
    "bumpp": "^7.1.1",
    "eslint": "^8.17.0",
    "esno": "^0.16.3",
    "pnpm": "^10.33.0",
    "tsup": "^6.1.0",
    "rimraf": "^3.0.2",
    "typescript": "^4.7.3",
    "vite": "^2.9.11",
    "vitest": "^0.14.1",
    "vsce": "^2.9.1",
    "fast-glob": "^3.3.1",
    "fs-extra": "^11.1.1",
    "@types/fs-extra": "^11.0.1"
  },
  "contributes": {
    "configuration": {
      "title": "i18n-auto-replace",
      "properties": {
        "i18n-auto-replace.ext": {
          "type": "array",
          "default": [
            "vue"
          ],
          "description": "需要被替换/移动 i18n 的 文件的 扩展名，默认为 vue 文件"
        },
        "i18n-auto-replace.localePath": {
          "type": "array",
          "default": [
            "src",
            "locales"
          ],
          "description": "i18n 文件所在的位置，默认值为 'src/locales'"
        },
        "i18n-auto-replace.srcPath": {
          "type": "array",
          "default": [
            "src"
          ],
          "description": "src 文件的目录，默认值为 src"
        },
        "i18n-auto-replace.enableDelete": {
          "type": "boolean",
          "default": false,
          "description": "是否在删除一个被检测文件时去删除对应的 i18n 文件，默认不删除"
        },
        "i18n-auto-replace.defaultLocaleLang": {
          "type": "string",
          "default": "zh-CN",
          "description": "默认打开的 locale 文件"
        },
        "i18n-auto-replace.exclude": {
          "type": "array",
          "default": [
            "src/locales"
          ],
          "description": "不参与 i18n 联动的路径前缀列表，默认排除 src/locales 目录本身"
        }
      }
    },
    "commands": [
      {
        "command": "i18n-auto-replace.openSpecificLocaleFile",
        "category": "I18n Auto Replace",
        "title": "%command_openSpecificLocaleFile%",
        "icon": "$(list-selection)"
      },
      {
        "command": "i18n-auto-replace.openLocaleFile",
        "category": "I18n Auto Replace",
        "title": "%command_openLocaleFile%",
        "icon": "$(globe)"
      },
      {
        "command": "i18n-auto-replace.copyRelativeKeyPath",
        "category": "I18n Auto Replace",
        "title": "%command_copyRelativeKeyPath%"
      },
      {
        "command": "i18n-auto-replace.quickCreatePairedLocaleFile",
        "category": "I18n Auto Replace",
        "title": "%command_quickCreatePairedLocaleFile%"
      },
      {
        "command": "i18n-auto-replace.openSourceFile",
        "category": "I18n Auto Replace",
        "title": "%command_openSourceFile%",
        "icon": "$(go-to-file)"
      },
      {
        "command": "i18n-auto-replace.openLocale.en-US",
        "category": "I18n Auto Replace",
        "title": "Open en-US"
      },
      {
        "command": "i18n-auto-replace.openLocale.zh-CN",
        "category": "I18n Auto Replace",
        "title": "Open zh-CN"
      },
      {
        "command": "i18n-auto-replace.openLocale.ja",
        "category": "I18n Auto Replace",
        "title": "Open ja"
      }
    ],
    "submenus": [
      {
        "id": "i18n-auto-replace.sourceFileMenu",
        "label": "I18n Auto Replace",
        "icon": {
          "light": "resources/i18n-light.svg",
          "dark": "resources/i18n-dark.svg"
        }
      },
      {
        "id": "i18n-auto-replace.localeFileMenu",
        "label": "I18n Auto Replace",
        "icon": {
          "light": "resources/i18n-light.svg",
          "dark": "resources/i18n-dark.svg"
        }
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "i18n-auto-replace.copyRelativeKeyPath",
          "group": "i18n-auto-replace"
        },
        {
          "command": "i18n-auto-replace.quickCreatePairedLocaleFile",
          "group": "i18n-auto-replace"
        },
        {
          "command": "i18n-auto-replace.openLocaleFile",
          "group": "i18n-auto-replace"
        },
        {
          "command": "i18n-auto-replace.openSpecificLocaleFile",
          "group": "i18n-auto-replace"
        }
      ],
      "editor/context": [
        {
          "command": "i18n-auto-replace.copyRelativeKeyPath",
          "group": "i18n-auto-replace"
        },
        {
          "command": "i18n-auto-replace.quickCreatePairedLocaleFile",
          "group": "i18n-auto-replace"
        },
        {
          "command": "i18n-auto-replace.openLocaleFile",
          "group": "i18n-auto-replace"
        },
        {
          "command": "i18n-auto-replace.openSpecificLocaleFile",
          "group": "i18n-auto-replace"
        }
      ],
      "editor/title": [
        {
          "submenu": "i18n-auto-replace.sourceFileMenu",
          "when": "i18nAutoReplace.isTargetFile",
          "group": "navigation@1"
        },
        {
          "submenu": "i18n-auto-replace.localeFileMenu",
          "when": "i18nAutoReplace.isLocaleFile",
          "group": "navigation@1"
        }
      ],
      "i18n-auto-replace.sourceFileMenu": [
        {
          "command": "i18n-auto-replace.openLocaleFile",
          "group": "1_open@1"
        },
        {
          "command": "i18n-auto-replace.openSpecificLocaleFile",
          "group": "1_open@2"
        },
        {
          "command": "i18n-auto-replace.openLocale.en-US",
          "group": "2_preset@1"
        },
        {
          "command": "i18n-auto-replace.openLocale.zh-CN",
          "group": "2_preset@2"
        },
        {
          "command": "i18n-auto-replace.openLocale.ja",
          "group": "2_preset@3"
        },
        {
          "command": "i18n-auto-replace.quickCreatePairedLocaleFile",
          "group": "3_create@1"
        }
      ],
      "i18n-auto-replace.localeFileMenu": [
        {
          "command": "i18n-auto-replace.openSourceFile",
          "group": "1_open@1"
        },
        {
          "command": "i18n-auto-replace.openSpecificLocaleFile",
          "group": "1_open@2"
        },
        {
          "command": "i18n-auto-replace.openLocale.en-US",
          "group": "2_preset@1"
        },
        {
          "command": "i18n-auto-replace.openLocale.zh-CN",
          "group": "2_preset@2"
        },
        {
          "command": "i18n-auto-replace.openLocale.ja",
          "group": "2_preset@3"
        }
      ]
    }
  }
}
